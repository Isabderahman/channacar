# Copy to .env and fill in. Used by docker-compose and the deploy scripts.

# ---- Laravel ----
# Leave APP_KEY empty; ./deploy.sh generates it on first run (or run:
#   docker compose run --rm backend php artisan key:generate --show)
APP_KEY=
ADMIN_USER_EMAIL=admin@channacar.com
ADMIN_USER_PASSWORD=ChangeMe123!

# ---- MySQL ----
MYSQL_DATABASE=channacar
MYSQL_USER=channacar
MYSQL_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

# ---- Let's Encrypt ----
CERTBOT_EMAIL=admin@chanaacar.com
# Set to 1 while testing to avoid Let's Encrypt rate limits (staging certs).
CERTBOT_STAGING=0
